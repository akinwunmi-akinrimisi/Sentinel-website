# =========================================================================
# Sentinel Institute — Vercel Environment Variables Template
# =========================================================================
# Use this file to wire the 15 keys from docs/pre-launch-qa.md §1 into your
# Vercel project. Three ways to import:
#
#   1. Vercel dashboard → Project → Settings → Environment Variables → "Import"
#      (paste the lines below, one KEY=value per line)
#   2. CLI: `vercel env add <KEY> production` for each line
#   3. CLI: `vercel env pull .env.production.local` after wiring in dashboard
#
# Each key is tagged:
#   [READY]    — copy the value below as-is into Vercel
#   [LOCAL]    — already real in your local .env or .env.local; copy from there
#   [GENERATE] — run the suggested command, then paste the output
#   [NEEDS]    — you must supply this (signup link / dashboard noted)
#
# NEVER commit a filled copy of this file with real secrets. The template
# itself is safe because every secret is a placeholder.
# =========================================================================

# --- Application ---------------------------------------------------------
# [READY]
NEXT_PUBLIC_SITE_URL=https://sentinelinstitute.com

# --- Sanity CMS ----------------------------------------------------------
# [LOCAL] In your local .env (8-char projectId)
NEXT_PUBLIC_SANITY_PROJECT_ID=__COPY_FROM_LOCAL_DOT_ENV__
# [READY]
NEXT_PUBLIC_SANITY_DATASET=production
# [LOCAL] In your local .env (180-char token, Editor scope)
SANITY_API_TOKEN=__COPY_FROM_LOCAL_DOT_ENV__
# [GENERATE] PowerShell: -join ((1..32) | ForEach-Object { '{0:x}' -f (Get-Random -Max 16) })
# Or: openssl rand -hex 16
# IMPORTANT: paste this SAME value into the Sanity webhook URL (QA §2).
SANITY_REVALIDATE_SECRET=__GENERATE_32_HEX_CHARS__

# --- Email (Resend) ------------------------------------------------------
# [NEEDS] Sign up at https://resend.com → API Keys → create "production"
RESEND_API_KEY=re___PASTE_FROM_RESEND_DASHBOARD__
# [READY]
RESEND_FROM_EMAIL=training@sentinelinstitute.com
RESEND_TO_EMAIL=training@sentinelinstitute.com

# --- Slack (internal lead notifications) ---------------------------------
# [NEEDS] Slack → Apps → Incoming Webhooks → install → pick #new-leads channel
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/__PASTE_FROM_SLACK__

# --- HubSpot (CRM contact sync) ------------------------------------------
# [NEEDS] HubSpot → Settings → Account Setup → Account Defaults
HUBSPOT_PORTAL_ID=__PASTE_HUBSPOT_HUB_ID__
# [NEEDS] HubSpot → Marketing → Forms → create "Sentinel Proposal" → copy form ID
HUBSPOT_FORM_ID=__PASTE_HUBSPOT_FORM_ID__

# --- Vercel KV (Upstash) — rate limiting on /api/proposal ----------------
# [NEEDS] Vercel dashboard → Storage → Create Database → KV → "sentinel-ratelimit"
# Both keys auto-populate via Vercel KV integration. If using Upstash directly,
# copy from upstash.com → your DB → REST API.
KV_REST_API_URL=__PASTE_FROM_VERCEL_KV__
KV_REST_API_TOKEN=__PASTE_FROM_VERCEL_KV__

# --- Analytics (GA4) -----------------------------------------------------
# [READY]
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-SX7492KRTM

# --- Booking (Cal.com) ---------------------------------------------------
# [READY]
NEXT_PUBLIC_CAL_LINK=https://cal.com/sentinelinstitute/discovery

# =========================================================================
# After import: redeploy the Vercel preview, then continue with QA §3+.
# =========================================================================
